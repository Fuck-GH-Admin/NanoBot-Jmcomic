# ==================== 基础配置 ====================
SUPERUSERS=["你的QQ号"]
NICKNAME=["机器人昵称"]

# ==================== WebSocket 配置 ====================
# LLOneBot 使用 ws-reverse 模式连接过来，NoneBot2 只需监听即可
DRIVER=~fastapi
HOST=127.0.0.1
PORT=8080

# ==================== 鉴权与调试 ====================
ONEBOT_V11_ACCESS_TOKEN="你的Token"
LOG_LEVEL=DEBUG
API_TIMEOUT=60.0
